{
  "name": "@ikieaneh/opencode-kit",
  "version": "0.5.7",
  "description": "Standardized OpenCode orchestration framework — contract-based, rules-enforced, zero-touch agent workflow. Install as plugin.",
  "license": "MIT",
  "author": "RizkiRachman",
  "type": "module",
  "main": ".opencode/plugins/opencode-kit.js",
  "exports": {
    ".": {
