  "keywords": [
    "opencode",
    "opencode-plugin",
    "orchestration",
    "workflow",
    "agents",
    "enforcement",
    "contract",
    "scoring",
    "adr"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RizkiRachman/opencode-kit"
  },
  "bugs": {
    "url": "https://github.com/RizkiRachman/opencode-kit/issues"
  },
  "homepage": "https://github.com/RizkiRachman/opencode-kit#readme"
