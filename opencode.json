    "snip": "deny",
    "lean-ctx_*": "allow"
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "gitnexus": {
      "type": "local",
      "command": [
        "npx",
        "gitnexus",
        "mcp"
      ]
    },
    "lean-ctx": {
      "type": "local",
      "command": [
        "/opt/homebrew/bin/lean-ctx"
      ],
      "enabled": true,
      "environment": {
        "LEAN_CTX_DATA_DIR": "/Users/rizkirachman/.lean-ctx"
      }
    },
    "postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@yawlabs/postgres-mcp@latest"
      ],
      "environment": {
        "DATABASE_URL": "${PG_MCP_URL}"
      }
    },
    "firecrawl": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firecrawl-mcp"
      ],
      "environment": {
        "FIRECRAWL_API_KEY": "fc-5d811dbf59ab49aab830ec5ceb734650"
      }
    }
