# opencode-kit environment configuration
#
# Two ways to provide credentials:
#
# Option A: Local .env file (per-project, gitignored)
#   cp .env.template .env
#   $EDITOR .env
#
# Option B: System environment (global, in ~/.zshrc or ~/.bashrc)
#   export FIRECRAWL_API_KEY=fc-...
#   export GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
#
# The plugin checks system env first, then .env file.
# If neither provides a required var, MCP servers will fail to connect.

# Firecrawl MCP
FIRECRAWL_API_KEY=fc-your_key_here

# GitHub MCP
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_token_here
